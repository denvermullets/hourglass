<%# locals: data, integration, team_id, frame_id %>
<% frame_id ||= "jait-project-#{team_id}-#{data['id']}" %>
<% url = "#{integration.base_url}/teams/#{team_id}/projects/#{data['id']}" %>
<% status = data['status'].to_s %>
<% pct = data['progress_percentage'] %>
<% completed = data['completed_issues_count'] %>
<% total = data['total_issues_count'] || data['issues_count'] %>
<%= turbo_frame_tag frame_id do %>
  <%= link_to url, target: "_blank", rel: "noopener noreferrer",
        class: "jait-card not-prose block max-w-md rounded-lg border border-granny-smith-apple-600 bg-bunker-875 hover:bg-bunker-825 transition px-3 py-2.5 my-1 no-underline" do %>
    <div class="flex items-center justify-between mb-1">
      <span class="text-xs tracking-[0.16em] text-bunker-600 font-dm-mono">PROJECT</span>
      <% if status.present? %>
        <span class="text-[10px] uppercase tracking-[0.14em] px-1.5 py-0.5 rounded border border-bunker-775 text-bunker-300"><%= status %></span>
      <% end %>
    </div>
    <div class="text-bunker-50 text-sm font-semibold leading-snug"><%= data['name'] %></div>
    <% if data['description'].present? %>
      <div class="text-bunker-300 text-xs leading-snug mt-1 line-clamp-2"><%= truncate(data['description'].to_s, length: 140) %></div>
    <% end %>
    <% if pct || total %>
      <div class="mt-2 flex items-center gap-2 text-[11px] text-bunker-300">
        <% if pct %>
          <div class="flex-1 h-1 rounded bg-bunker-825 overflow-hidden">
            <div class="h-full bg-granny-smith-apple-400" style="width: <%= [[pct.to_i, 0].max, 100].min %>%"></div>
          </div>
          <span class="text-bunker-300"><%= pct.to_i %>%</span>
        <% end %>
        <% if completed && total %>
          <span class="text-bunker-500"><%= completed %>/<%= total %></span>
        <% end %>
        <% if data['lead'] && data['lead']['name'].present? %>
          <span class="ml-auto inline-flex items-center justify-center w-5 h-5 rounded-full bg-bunker-825 text-bunker-50 text-[10px] font-bold" title="<%= data['lead']['name'] %>">
            <%= data['lead']['name'].first.upcase %>
          </span>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% end %>
