<%# locals: data, integration, team_id, frame_id %>
<% frame_id ||= "jait-issue-#{team_id}-#{data['id']}" %>
<% url = "#{integration.base_url}/teams/#{team_id}/issues/#{data['id']}" %>
<% lane = data['lane'] || {} %>
<% labels = data['labels'] || [] %>
<% priority = data['priority'].to_s %>
<%= turbo_frame_tag frame_id, data: { turbo_permanent: true } do %>
  <%= link_to url, target: "_blank", rel: "noopener noreferrer",
        class: "jait-card not-prose block max-w-md rounded-lg border border-granny-smith-apple-600 bg-bunker-875 hover:bg-bunker-825 transition px-3 py-2.5 my-1 no-underline" do %>
    <div class="flex items-center justify-between mb-1">
      <span class="text-xs tracking-[0.16em] text-bunker-600 font-dm-mono"><%= data['identifier'] %></span>
      <% if lane['name'].present? %>
        <span class="text-[10px] uppercase tracking-[0.14em] px-1.5 py-0.5 rounded border border-bunker-775 text-bunker-300"><%= lane['name'] %></span>
      <% end %>
    </div>
    <div class="text-bunker-50 text-sm font-semibold leading-snug"><%= data['title'] %></div>
    <% if data['project'] || data['assignee'] || (priority.present? && priority != 'no_priority') || labels.any? %>
      <div class="mt-2 flex flex-wrap items-center gap-1.5 text-[11px] text-bunker-300">
        <% if data['project'] && data['project']['name'].present? %>
          <span class="px-1.5 py-0.5 rounded border border-bunker-775"><%= data['project']['name'] %></span>
        <% end %>
        <% if priority.present? && priority != 'no_priority' %>
          <span class="px-1.5 py-0.5 rounded border border-bunker-775"><%= priority.tr('_', ' ') %></span>
        <% end %>
        <% labels.first(3).each do |l| %>
          <span class="px-1.5 py-0.5 rounded border border-bunker-775"><%= l['name'] %></span>
        <% end %>
        <% if data['assignee'] && data['assignee']['name'].present? %>
          <span class="ml-auto inline-flex items-center justify-center w-5 h-5 rounded-full bg-bunker-825 text-bunker-50 text-[10px] font-bold" title="<%= data['assignee']['name'] %>">
            <%= data['assignee']['name'].first.upcase %>
          </span>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% end %>
