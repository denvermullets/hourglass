<%# Header %>
<div class="flex items-center justify-between px-3 py-2.5 border-b border-bunker-825">
  <div>
    <span class="text-xs text-bunker-600 tracking-[0.1em] uppercase block">activity</span>
    <span class="text-xs text-bunker-200 font-bold">notifications</span>
  </div>
  <button data-mark-all-read
          class="text-xs text-granny-smith-apple-400 hover:text-granny-smith-apple-300 bg-transparent border-0 cursor-pointer p-0 font-dm-mono">
    mark all read
  </button>
</div>

<%# Notification list %>
<div id="notification_list" class="flex-1 overflow-y-auto">
  <% if @notifications.any? %>
    <% @notifications.each do |notification| %>
      <%= render "notifications/notification", notification: notification %>
    <% end %>
  <% else %>
    <div class="flex flex-col items-center justify-center py-12 px-4">
      <svg class="w-8 h-8 text-bunker-800 mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
      </svg>
      <p class="text-xs text-bunker-600 m-0">no notifications yet</p>
    </div>
  <% end %>
</div>
