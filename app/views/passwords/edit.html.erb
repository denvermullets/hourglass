<% content_for(:brand_description) do %>
  choose a new password for your account.
<% end %>

<div>
  <div class="mb-6">
    <div class="text-xs tracking-[0.2em] flex items-center gap-1 text-bunker-500">
      <span class="text-bunker-600">//</span> account
    </div>
    <h1 class="font-syne text-2xl font-bold tracking-tight mt-1 text-bunker-50">reset password</h1>
    <p class="text-xs mt-1 leading-relaxed text-bunker-500">enter your new password below.</p>
  </div>

  <%= render "shared/auth_flash" %>

  <%= form_with url: password_path(params[:token]), method: :put, class: "flex flex-col gap-3.5" do |form| %>
    <div class="flex flex-col gap-1">
      <label class="text-xs tracking-[0.16em] flex items-center gap-1.5 text-bunker-500">
        <span class="text-granny-smith-apple-600">$</span> new_password <span class="text-danger-400 opacity-80">*</span>
      </label>
      <%= form.password_field :password,
        required: true,
        autocomplete: "new-password",
        placeholder: "min 8 characters",
        maxlength: 72,
        class: "w-full rounded px-3 py-2.5 font-dm-mono text-xs outline-none transition-colors duration-150 bg-bunker-875 border border-bunker-775 text-bunker-300",
        onfocus: "this.classList.replace('border-bunker-775','border-granny-smith-apple-600')",
        onblur: "this.classList.replace('border-granny-smith-apple-600','border-bunker-775')" %>
    </div>

    <div class="flex flex-col gap-1">
      <label class="text-xs tracking-[0.16em] flex items-center gap-1.5 text-bunker-500">
        <span class="text-granny-smith-apple-600">$</span> confirm_password <span class="text-danger-400 opacity-80">*</span>
      </label>
      <%= form.password_field :password_confirmation,
        required: true,
        autocomplete: "new-password",
        placeholder: "repeat new password",
        maxlength: 72,
        class: "w-full rounded px-3 py-2.5 font-dm-mono text-xs outline-none transition-colors duration-150 bg-bunker-875 border border-bunker-775 text-bunker-300",
        onfocus: "this.classList.replace('border-bunker-775','border-granny-smith-apple-600')",
        onblur: "this.classList.replace('border-granny-smith-apple-600','border-bunker-775')" %>
    </div>

    <%= form.submit "// update password \u2192",
      class: "w-full rounded px-3.5 py-2.5 font-dm-mono text-xs tracking-[0.06em] text-center cursor-pointer transition-colors duration-150 bg-transparent border border-granny-smith-apple-600 text-granny-smith-apple-300 hover:bg-granny-smith-apple-600 hover:text-bunker-950" %>
  <% end %>
</div>
