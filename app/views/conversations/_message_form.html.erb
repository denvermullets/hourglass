<%= form_with scope: :message, url: conversation_messages_path(conversation),
             id: "message_form",
             data: {
               turbo_permanent: true,
               controller: "message-input attachment-upload",
               action: "turbo:submit-end->message-input#reset turbo:submit-end->attachment-upload#reset",
               message_input_server_id_value: "",
               message_input_channel_linked_value: false
             } do |f| %>
  <input type="file" multiple class="hidden" data-attachment-upload-target="fileInput" data-action="change->attachment-upload#filesSelected">

  <div class="bg-bunker-950 border border-bunker-900 rounded-lg overflow-clip focus-within:border-granny-smith-apple-600 transition-colors duration-150">
    <%# Attachment preview strip %>
    <div data-attachment-upload-target="previewStrip"
         class="hidden border-b border-bunker-900 px-3 py-2 flex gap-2 items-center overflow-x-auto scrollbar-none">
    </div>

    <%# Markdown textarea %>
    <%= f.text_area :body,
          placeholder: "// message #{conversation.display_name(Current.user)}",
          rows: 1,
          data: {
            message_input_target: "textarea",
            action: "paste->attachment-upload#handlePaste drop->attachment-upload#handleDrop dragover->attachment-upload#handleDragOver"
          },
          class: "block w-full resize-none min-h-9 max-h-50 overflow-y-auto px-3 py-2.5 text-base sm:text-xs text-bunker-50 placeholder:text-bunker-600 font-dm-mono bg-transparent border-0 focus:outline-none focus:ring-0" %>

    <%# Toolbar footer %>
    <div class="flex items-center gap-1 px-2 py-1.5 border-t border-bunker-900">
      <button type="button" data-action="mousedown->message-input#preventFocusLoss click->message-input#bold" data-format="bold"
              class="toolbar-btn" title="Bold (Ctrl+B)"><strong>B</strong></button>
      <button type="button" data-action="mousedown->message-input#preventFocusLoss click->message-input#italic" data-format="italic"
              class="toolbar-btn" title="Italic (Ctrl+I)"><em>I</em></button>
      <button type="button" data-action="mousedown->message-input#preventFocusLoss click->message-input#strikethrough" data-format="strikethrough"
              class="toolbar-btn" title="Strikethrough"><s>S</s></button>
      <button type="button" data-action="mousedown->message-input#preventFocusLoss click->message-input#code" data-format="code"
              class="toolbar-btn" title="Inline Code">&lt;/&gt;</button>
      <button type="button" data-action="mousedown->message-input#preventFocusLoss click->message-input#codeBlock"
              class="toolbar-btn" title="Code Block">{}</button>

      <button type="button" data-action="mousedown->message-input#preventFocusLoss click->attachment-upload#openFilePicker"
              class="toolbar-btn" title="Attach file">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="17 8 12 3 7 8"></polyline>
          <line x1="12" y1="3" x2="12" y2="15"></line>
        </svg>
      </button>

      <div class="hidden sm:flex items-center gap-0.5 ml-auto">
        <button type="button" data-action="mousedown->message-input#preventFocusLoss click->message-input#resizeDefault"
                class="toolbar-btn active" data-message-input-target="resizeBtn" data-size="default" title="Default size">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="18" x2="21" y2="18"/><line x1="3" y1="12" x2="21" y2="12"/></svg>
        </button>
        <button type="button" data-action="mousedown->message-input#preventFocusLoss click->message-input#resizeHalf"
                class="toolbar-btn" data-message-input-target="resizeBtn" data-size="half" title="Half viewport">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="10" width="18" height="11" rx="1"/><line x1="3" y1="6" x2="21" y2="6"/></svg>
        </button>
        <button type="button" data-action="mousedown->message-input#preventFocusLoss click->message-input#resizeFull"
                class="toolbar-btn" data-message-input-target="resizeBtn" data-size="full" title="Full viewport">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="1"/></svg>
        </button>

        <span class="text-xs text-bunker-600 font-dm-mono ml-1">
          <span class="text-granny-smith-apple-600">md</span> supported
        </span>
      </div>

      <%= f.submit "send",
            class: "sm:ml-2 ml-auto bg-transparent text-xs text-bunker-500 hover:text-granny-smith-apple-300 transition-colors duration-150 cursor-pointer font-dm-mono uppercase tracking-[0.1em] border-0 p-0" %>
    </div>
  </div>
<% end %>
