<%# Desktop conversation sidebar — 240px %>
<div class="w-60 flex-shrink-0 border-r border-bunker-825 flex flex-col h-full">
  <%# Header %>
  <div class="px-3.5 py-3 border-b border-bunker-825 flex items-center justify-between">
    <div class="flex-1 min-w-0">
      <h2 class="font-syne text-base font-bold text-bunker-50 truncate">direct messages</h2>
      <div class="text-xs tracking-[0.1em] mt-1.5 text-bunker-500 font-dm-mono">
        <span class="text-granny-smith-apple-600">//</span> <%= conversations.size %> conversation<%= conversations.size == 1 ? "" : "s" %>
      </div>
    </div>
    <%= link_to new_conversation_path,
      class: "w-7 h-7 rounded flex items-center justify-center border border-bunker-775 text-bunker-500 hover:bg-bunker-875 hover:text-bunker-300 transition-colors duration-100 no-underline" do %>
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 5v14M5 12h14"/>
      </svg>
    <% end %>
  </div>

  <%# Conversation list %>
  <div id="conversation_list" class="flex-1 overflow-y-auto py-2">
    <% if conversations.any? %>
      <% conversations.each do |conversation| %>
        <%= render "conversations/sidebar_item", conversation: conversation, current_conversation: current_conversation, unread_conversation_ids: local_assigns[:unread_conversation_ids] %>
      <% end %>
    <% else %>
      <div class="text-center py-8">
        <div class="text-xs text-bunker-500 mb-1">no conversations yet</div>
        <div class="text-xs text-bunker-600">start a new message.</div>
      </div>
    <% end %>
  </div>
</div>
