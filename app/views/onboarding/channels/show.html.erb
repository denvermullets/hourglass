<% content_for(:brand_description) do %>
  join an existing server with an invite code, or create your own.<br><br>
  servers are where your channels and conversations live.
<% end %>
<% content_for(:brand_footer) do %>
  step 3 of 3 &middot; server
<% end %>

<div>
  <div class="mb-6">
    <%= render "onboarding/progress_bar", current_step: 3 %>
  </div>

  <%= render "shared/auth_flash" %>

  <%= form_with url: onboarding_channels_path, method: :patch, class: "flex flex-col gap-3.5" do |form| %>
    <%# Invite code %>
    <div class="flex flex-col gap-1">
      <label class="text-[8px] tracking-[0.16em] flex items-center gap-1.5 text-bunker-500">
        <span class="text-granny-smith-apple-600">$</span> invite_code
      </label>
      <%= form.text_field :invite_code,
        autofocus: true,
        placeholder: "paste an invite code",
        class: "w-full rounded px-3 py-2.5 font-dm-mono text-[11px] outline-none transition-colors duration-150 bg-bunker-875 border border-bunker-775 text-bunker-300 placeholder:text-bunker-600 focus:border-granny-smith-apple-600" %>
      <div class="text-[9px] leading-relaxed text-bunker-500">ask a friend for their server invite code</div>
    </div>

    <%= form.submit "// join server \u2192",
      class: "w-full rounded px-3.5 py-2.5 font-dm-mono text-[11px] tracking-[0.06em] text-center cursor-pointer transition-colors duration-150 bg-transparent border border-granny-smith-apple-600 text-granny-smith-apple-300 hover:bg-granny-smith-apple-600 hover:text-bunker-950" %>
  <% end %>

  <div class="flex items-center gap-2.5 my-1">
    <div class="flex-1 h-px bg-bunker-775"></div>
    <span class="text-[8px] tracking-[0.1em] text-bunker-600">or</span>
    <div class="flex-1 h-px bg-bunker-775"></div>
  </div>

  <%= button_to "// create your own server \u2192", onboarding_channels_path, method: :patch,
    class: "w-full rounded px-3.5 py-2.5 font-dm-mono text-[11px] tracking-[0.06em] text-center cursor-pointer transition-colors duration-150 bg-transparent border border-bunker-775 text-bunker-500 hover:border-bunker-600 hover:text-bunker-400" %>

  <div class="mt-3.5">
    <%= link_to "\u2190 back", onboarding_profile_path, class: "text-[9px] text-bunker-500 hover:text-bunker-400 no-underline" %>
  </div>
</div>
