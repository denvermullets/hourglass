<% content_for(:brand_description) do %>
  you've been invited.<br><br>
  create your account to join the conversation. it takes about a minute.
<% end %>
<% content_for(:brand_footer) do %>
  step 1 of 3 &middot; credentials
<% end %>

<div>
  <div class="mb-6">
    <%= render "onboarding/progress_bar", current_step: 1 %>
  </div>

  <%= render "shared/auth_flash" %>

  <%= form_with model: @user, url: onboarding_credentials_path, class: "flex flex-col gap-3.5" do |form| %>
    <%# Username %>
    <div class="flex flex-col gap-1">
      <label class="text-xs tracking-[0.16em] flex items-center gap-1.5 text-bunker-500">
        <span class="text-granny-smith-apple-600">$</span> username <span class="text-danger-400 opacity-80">*</span>
      </label>
      <%= form.text_field :username,
        required: true,
        autofocus: true,
        autocomplete: "username",
        placeholder: "your_handle",
        class: "w-full rounded px-3 py-2.5 font-dm-mono text-xs outline-none transition-colors duration-150 bg-bunker-875 border text-bunker-300 placeholder:text-bunker-600 #{@user.errors[:username].any? ? 'border-danger-800' : 'border-bunker-775'} focus:border-granny-smith-apple-600" %>
      <% if @user.errors[:username].any? %>
        <div class="text-xs leading-relaxed text-danger-400">// <%= @user.errors[:username].first %></div>
      <% else %>
        <div class="text-xs leading-relaxed text-bunker-500">lowercase, no spaces &middot; this is how others see you</div>
      <% end %>
    </div>

    <%# Email %>
    <div class="flex flex-col gap-1">
      <label class="text-xs tracking-[0.16em] flex items-center gap-1.5 text-bunker-500">
        <span class="text-granny-smith-apple-600">$</span> email <span class="text-danger-400 opacity-80">*</span>
      </label>
      <%= form.email_field :email_address,
        required: true,
        autocomplete: "email",
        placeholder: "you@example.com",
        class: "w-full rounded px-3 py-2.5 font-dm-mono text-xs outline-none transition-colors duration-150 bg-bunker-875 border text-bunker-300 placeholder:text-bunker-600 #{@user.errors[:email_address].any? ? 'border-danger-800' : 'border-bunker-775'} focus:border-granny-smith-apple-600" %>
      <% if @user.errors[:email_address].any? %>
        <div class="text-xs leading-relaxed text-danger-400">// <%= @user.errors[:email_address].first %></div>
      <% end %>
    </div>

    <%# Password with strength indicator %>
    <div class="flex flex-col gap-1" data-controller="password-strength">
      <label class="text-xs tracking-[0.16em] flex items-center gap-1.5 text-bunker-500">
        <span class="text-granny-smith-apple-600">$</span> password <span class="text-danger-400 opacity-80">*</span>
      </label>
      <%= form.password_field :password,
        required: true,
        autocomplete: "new-password",
        placeholder: "min 8 characters",
        maxlength: 72,
        data: { password_strength_target: "input", action: "input->password-strength#evaluate" },
        class: "w-full rounded px-3 py-2.5 font-dm-mono text-xs outline-none transition-colors duration-150 bg-bunker-875 border text-bunker-300 placeholder:text-bunker-600 #{@user.errors[:password].any? ? 'border-danger-800' : 'border-bunker-775'} focus:border-granny-smith-apple-600" %>
      <div class="flex items-center gap-2">
        <div class="flex-1 bg-bunker-775 rounded-sm h-1">
          <div data-password-strength-target="bar" class="rounded-sm h-1 transition-all duration-200" style="width: 0%"></div>
        </div>
        <span data-password-strength-target="label" class="text-xs tracking-[0.08em] text-bunker-600"></span>
      </div>
      <% if @user.errors[:password].any? %>
        <div class="text-xs leading-relaxed text-danger-400">// <%= @user.errors[:password].first %></div>
      <% end %>
    </div>

    <%# Password confirmation %>
    <div class="flex flex-col gap-1">
      <label class="text-xs tracking-[0.16em] flex items-center gap-1.5 text-bunker-500">
        <span class="text-granny-smith-apple-600">$</span> password_confirmation <span class="text-danger-400 opacity-80">*</span>
      </label>
      <%= form.password_field :password_confirmation,
        required: true,
        autocomplete: "new-password",
        placeholder: "confirm password",
        maxlength: 72,
        class: "w-full rounded px-3 py-2.5 font-dm-mono text-xs outline-none transition-colors duration-150 bg-bunker-875 border text-bunker-300 placeholder:text-bunker-600 #{@user.errors[:password_confirmation].any? ? 'border-danger-800' : 'border-bunker-775'} focus:border-granny-smith-apple-600" %>
      <% if @user.errors[:password_confirmation].any? %>
        <div class="text-xs leading-relaxed text-danger-400">// <%= @user.errors[:password_confirmation].first %></div>
      <% end %>
    </div>

    <%= form.submit "// next \u2192",
      class: "w-full rounded px-3.5 py-2.5 font-dm-mono text-xs tracking-[0.06em] text-center cursor-pointer transition-colors duration-150 bg-transparent border border-granny-smith-apple-600 text-granny-smith-apple-300 hover:bg-granny-smith-apple-600 hover:text-bunker-950" %>

    <div class="text-xs text-center text-bunker-500">
      already have an account? <%= link_to "sign in", new_session_path, class: "text-granny-smith-apple-600 no-underline" %>
    </div>
  <% end %>
</div>
