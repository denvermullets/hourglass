<%# Root message card with connector stem %>
<div class="px-4 lg:px-7 pt-5">
  <div class="border border-bunker-825 rounded-lg bg-bunker-875 px-4 py-3.5 relative after:content-[''] after:absolute after:left-7.5 after:-bottom-px after:w-0.5 after:h-3.5 after:bg-bunker-825">
    <%# Header %>
    <div class="flex items-center gap-2.5 mb-2">
      <div class="w-7.5 h-7.5 rounded-md bg-bunker-825 border border-bunker-775 flex items-center justify-center flex-shrink-0 overflow-hidden">
        <% if message.user.avatar.attached? %>
          <%= image_tag polymorphic_path(message.user.avatar), alt: "", class: "w-full h-full object-cover" %>
        <% else %>
          <span class="text-xs font-syne font-bold text-granny-smith-apple-300 uppercase"><%= message.user.username[0..1] %></span>
        <% end %>
      </div>
      <span class="text-xs font-medium text-granny-smith-apple-300"><%= message.user.username %></span>
      <span class="text-xs text-bunker-500 ml-auto"><%= format_timestamp(message.created_at, style: :thread_root) %></span>
    </div>

    <%# Body %>
    <% if message.body.present? %>
      <div class="text-xs text-bunker-300 leading-[1.8] font-light message-content">
        <%= sanitize_message(message.body) %>
      </div>
    <% end %>

    <%# Attachments %>
    <% if message.files.attached? %>
      <%= render "messages/attachments", message: message %>
    <% end %>
  </div>
</div>
