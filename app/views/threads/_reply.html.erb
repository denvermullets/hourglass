<% grouped = local_assigns.fetch(:grouped, false) %>
<%= tag.div id: dom_id(reply), class: "group flex gap-3 #{ grouped ? '' : 'py-2.5' } border-b border-bunker-825 last:border-b-0", data: { message_author_id: reply.user_id, message_user_id: reply.user_id, message_created_at: reply.created_at.iso8601, controller: "long-press" } do %>
  <% if reply.deleted? %>
    <div class="flex-1 text-[11px] text-bunker-700 italic">
      [message deleted]
    </div>
  <% else %>
    <% if grouped %>
      <%# Spacer matching avatar width %>
      <div class="flex-shrink-0 w-[30px]"></div>
    <% else %>
      <%# Avatar %>
      <div class="flex-shrink-0 w-[30px] h-[30px] rounded-md bg-bunker-825 border border-bunker-775 flex items-center justify-center mt-0.5 overflow-hidden">
        <% if reply.user.avatar.attached? %>
          <%= image_tag polymorphic_path(reply.user.avatar), alt: "", class: "w-full h-full object-cover" %>
        <% else %>
          <span class="text-[9px] font-syne font-bold text-bunker-400 uppercase"><%= reply.user.username[0..1] %></span>
        <% end %>
      </div>
    <% end %>

    <div class="flex-1 min-w-0">
      <% unless grouped %>
        <%# Header %>
        <div class="flex items-baseline gap-2.5 mb-1">
          <span class="text-[12px] font-medium message-username" data-author-name><%= reply.user.username %></span>
          <span class="text-[9px] text-bunker-600 tracking-[0.06em]"><%= reply.created_at.strftime("%H:%M:%S") %></span>
          <% if reply.edited? %>
            <span class="text-[9px] text-bunker-700">(edited)</span>
          <% end %>
        </div>
      <% end %>

      <%# Body %>
      <% if reply.body.present? %>
        <div class="text-[12px] text-bunker-400 leading-[1.8] font-light message-content"><%= sanitize_message(reply.body) %></div>
      <% end %>

      <%# Attachments %>
      <% if reply.files.attached? %>
        <%= render "messages/attachments", message: reply %>
      <% end %>

      <%# Actions — below reply content %>
      <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-100 flex items-center gap-2 mt-1 message-actions hidden"
           data-author-only
           data-long-press-target="actions">
        <%= button_to "edit",
              edit_server_channel_message_path(server, channel, reply),
              method: :get,
              class: "text-[9px] text-bunker-700 hover:text-bunker-400 transition-colors duration-100 bg-transparent border-0 p-0 cursor-pointer" %>
        <%= button_to "delete",
              server_channel_message_path(server, channel, reply),
              method: :delete,
              class: "text-[9px] text-bunker-700 hover:text-danger-400 transition-colors duration-100 bg-transparent border-0 p-0 cursor-pointer",
              data: { turbo_confirm: "Delete this reply?" } %>
      </div>
    </div>
  <% end %>
<% end %>
