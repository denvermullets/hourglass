<div class="flex-1 flex flex-col lg:flex-row min-h-0">
  <%# Collapsed channel sidebar — desktop only %>
  <div class="hidden lg:flex">
    <%= render "threads/collapsed_sidebar", server: @server, categories: @categories, current_channel: @channel %>
  </div>

  <%# Pinned content %>
  <div class="flex-1 flex flex-col min-w-0 min-h-0 relative">
    <%# Header %>
    <div class="px-4 lg:px-7 py-3.5 border-b border-bunker-825 flex-shrink-0 flex items-center gap-3">
      <%# Back button %>
      <%= link_to server_channel_path(@server, @channel),
        class: "text-xs text-granny-smith-apple-600 no-underline flex-shrink-0 flex items-center gap-1.5 px-2.5 py-1.5 border border-bunker-825 rounded hover:border-granny-smith-apple-600 transition-colors duration-100" do %>
        &larr; back
      <% end %>

      <div class="w-px h-4.5 bg-bunker-825 flex-shrink-0"></div>

      <div class="flex-1 min-w-0">
        <%# Breadcrumb %>
        <div class="text-xs text-bunker-500 tracking-[0.12em] flex items-center gap-1.5">
          <span># <%= @channel.name %></span>
          <span class="text-bunker-775">/</span>
          <span class="text-granny-smith-apple-600">pinned messages</span>
        </div>
        <div class="font-syne text-base font-bold text-bunker-50 mt-0.5 tracking-tight">pinned messages</div>
        <div class="text-xs text-bunker-500 mt-0.5"><%= @pinned_messages.size %> message<%= @pinned_messages.size == 1 ? '' : 's' %> pinned</div>
      </div>
    </div>

    <%# List — scrollable %>
    <div class="flex-1 flex flex-col min-h-0 overflow-hidden"
         data-controller="message-actions"
         data-message-actions-current-user-value="<%= Current.user.id %>">
      <%= turbo_stream_from @channel %>

      <div class="flex-1 overflow-y-auto px-4 lg:px-7 py-4 space-y-1">
        <% if @pinned_messages.empty? %>
          <div class="text-center py-12">
            <div class="text-xs text-bunker-500 mb-1">no pinned messages yet</div>
            <div class="text-xs text-bunker-600">hover any message in <span class="text-bunker-300">#<%= @channel.name %></span> and click pin</div>
          </div>
        <% else %>
          <% @pinned_messages.each do |message| %>
            <%= render "messages/message", message: message, context: :channel %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
