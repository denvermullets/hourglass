<!DOCTYPE html>
<html data-theme="<%= Current.user&.theme || 'cold-wave' %>" data-sidebar="<%= Current.user&.sidebar_position || 'left' %>" data-text-size="<%= Current.user&.text_size || 'xs' %>" data-text-size-mobile="<%= Current.user&.text_size_mobile || 'xs' %>">
  <head>
    <title><%= content_for(:title) || "Hourglass" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Hourglass">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Turbo 8 page-refresh strategy: morph in place, preserve scroll (Phase 2 polling migration) %>
    <%= turbo_refresh_method_tag :morph %>
    <%= turbo_refresh_scroll_tag :preserve %>
    <meta name="poll-digest" content="<%= poll_digest %>">

    <%= yield :head %>

    <link rel="icon" href="/icons/<%= Current.user&.theme || 'cold-wave' %>.svg" type="image/svg+xml">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="font-dm-mono bg-bunker-950 text-bunker-300 h-dvh overflow-hidden"
        data-controller="notifications-channel notification-panel poller"
        data-poller-url-value="<%= poll_path %>"
        data-poller-channel-id-value="<%= @channel&.id %>"
        data-poller-conversation-id-value="<%= @conversation&.id %>"
        data-poller-thread-id-value="<%= @parent_message&.id %>">
    <%# Notification panel overlay %>
    <div data-notification-panel-target="overlay"
         data-action="click->notification-panel#close"
         class="hidden fixed inset-0 bg-black/30 z-40"></div>

    <%# Notification panel %>
    <div data-notification-panel-target="panel"
         class="hidden fixed top-0 right-0 h-full w-80 bg-bunker-925 border-l border-bunker-825 z-50 flex flex-col shadow-2xl">
      <div data-notification-panel-target="content" class="flex flex-col h-full">
        <%# Content loaded dynamically %>
      </div>
    </div>

    <%# Unread title indicator — Turbo Stream target for tab dot.
        Controller lives on the wrapper so it survives replacement of #unread_title_indicator. %>
    <span data-controller="unread-title"
          data-unread-title-base-value="<%= content_for(:title) || 'Hourglass' %>"
          class="hidden">
      <span id="unread_title_indicator">
        <% if Current.user&.unread_channels? || Current.user&.unread_conversations? %><span data-unread="true"></span><% end %>
      </span>
    </span>

    <div class="flex h-full sidebar-container">
      <%# Desktop icon rail — hidden on mobile %>
      <div class="hidden lg:flex">
        <%= render "shared/icon_rail", current_server: defined?(@server) ? @server : nil %>
      </div>

      <%# Main content area %>
      <div class="flex-1 flex flex-col min-w-0 min-h-0 pb-14 lg:pb-0">
        <%= render "shared/auth_flash" %>
        <%= yield %>
      </div>
    </div>

    <%# Mobile bottom nav — hidden on desktop %>
    <div class="lg:hidden">
      <%= render "shared/bottom_nav" %>
    </div>
  </body>
</html>
