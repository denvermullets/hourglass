<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Hourglass" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Hourglass">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icons/cold-wave.svg" type="image/svg+xml">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="font-dm-mono bg-bunker-950">
    <div class="flex min-h-screen">
      <%# Left brand panel %>
      <div class="hidden lg:flex w-[340px] flex-shrink-0 flex-col justify-between p-10 pb-8 border-r border-bunker-825">
        <div>
          <div class="font-syne text-4xl font-extrabold tracking-tight text-bunker-50">
            hour<span class="text-granny-smith-apple-300">.</span>glass
          </div>
          <div class="text-xs tracking-[0.16em] mt-2 text-bunker-500">
            <span class="text-granny-smith-apple-600">// </span>time to build
          </div>
          <div class="text-xs mt-7 leading-7 font-light text-bunker-500">
            <%= content_for?(:brand_description) ? yield(:brand_description) : "a simple way to track where your time goes." %>
          </div>
        </div>
        <div class="text-xs leading-7 text-bunker-600">
          <%= content_for?(:brand_footer) ? yield(:brand_footer) : "" %>
        </div>
      </div>

      <%# Right content panel %>
      <div class="flex-1 flex items-center justify-center p-10">
        <div class="w-full max-w-[380px]">
          <%= yield %>
        </div>
      </div>
    </div>
  </body>
</html>
