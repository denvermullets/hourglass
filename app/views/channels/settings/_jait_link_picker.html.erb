<%# locals: server, channel, integration %>
<% input_classes = "w-full rounded px-3 py-2.5 font-dm-mono text-xs outline-none transition-colors duration-150 bg-bunker-875 border border-bunker-775 text-bunker-300 placeholder:text-bunker-600 focus:border-granny-smith-apple-600" %>
<% teams = Array(integration.discovered_teams) %>

<dialog id="jait_project_picker"
        data-project-picker-target="dialog"
        class="fixed inset-0 m-auto rounded-lg bg-bunker-925 border border-bunker-825 text-bunker-300 w-[480px] max-w-[95vw] max-h-[80vh] p-0 backdrop:bg-bunker-950/60">
  <div class="flex flex-col">
    <div class="px-4 py-3 border-b border-bunker-825 flex items-center justify-between">
      <div>
        <div class="text-xs tracking-[0.16em] text-granny-smith-apple-300 font-dm-mono">// pick a project</div>
        <div class="text-[11px] text-bunker-500 mt-0.5">link <span class="text-bunker-300">#<%= channel.name %></span> to a mtasks project</div>
      </div>
      <button type="button" data-action="project-picker#close"
        class="text-bunker-500 hover:text-bunker-300 text-xs cursor-pointer bg-transparent border-0">close</button>
    </div>

    <div class="px-4 py-3 border-b border-bunker-825 flex flex-col gap-2">
      <% if teams.size > 1 %>
        <select data-project-picker-target="team"
                data-action="change->project-picker#search"
                class="<%= input_classes %>">
          <% teams.each do |t| %>
            <option value="<%= t['id'] %>"><%= t['identifier'] %> &middot; <%= t['name'] %></option>
          <% end %>
        </select>
      <% else %>
        <% only_team = teams.first %>
        <input type="hidden" data-project-picker-target="team" value="<%= only_team&.dig('id') %>">
        <div class="text-[11px] text-bunker-500 font-dm-mono">team: <%= only_team&.dig('identifier') %> &middot; <%= only_team&.dig('name') %></div>
      <% end %>

      <input type="search"
             placeholder="search projects…"
             autocomplete="off"
             data-project-picker-target="search"
             data-action="input->project-picker#search"
             class="<%= input_classes %>">
    </div>

    <div data-project-picker-target="results"
         class="flex flex-col gap-1 px-2 py-3 max-h-[320px] overflow-y-auto">
      <div class="text-xs text-bunker-500 py-4 text-center">loading…</div>
    </div>

    <%= form_with url: link_project_server_channel_settings_path(server, channel),
          method: :post, scope: nil, data: { project_picker_target: "form" } do |f| %>
      <%= hidden_field_tag :team_id, '', data: { project_picker_target: "teamInput" } %>
      <%= hidden_field_tag :project_id, '', data: { project_picker_target: "projectInput" } %>
    <% end %>
  </div>
</dialog>
