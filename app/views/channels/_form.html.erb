<%= form_with model: Channel.new, url: server_channels_path(server), class: "flex items-center gap-2" do |f| %>
  <%= f.hidden_field :category_id, value: category.id %>
  <%= f.text_field :name,
    placeholder: "// new channel",
    class: "flex-1 min-w-0 bg-bunker-950 border border-bunker-900 rounded px-2 py-1 text-[10px] text-bunker-300 placeholder:text-bunker-700 focus:outline-none focus:border-bunker-600 font-dm-mono" %>
  <%= f.submit "+",
    class: "w-6 h-6 rounded flex items-center justify-center border border-bunker-775 text-bunker-600 hover:bg-bunker-875 hover:text-bunker-400 transition-colors duration-100 cursor-pointer bg-transparent text-[12px]" %>
<% end %>
