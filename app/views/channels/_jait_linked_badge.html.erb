<%# locals: channel %>
<% link = channel.mtasks_project_link %>
<% return unless link %>
<% integration = link.server_integration %>
<% project = Jait::Fetcher.call(integration: integration, kind: 'project', team_id: link.mtasks_team_id, id: link.mtasks_project_id) %>
<% return unless project %>

<%= link_to server_channel_settings_path(channel.server, channel),
      class: "inline-flex items-center gap-1 text-bunker-500 hover:text-bunker-300 no-underline" do %>
  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
    <path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07l-1.5 1.5"/>
    <path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 0 0 7.07 7.07l1.5-1.5"/>
  </svg>
  <span>linked: <%= project['name'] %></span>
<% end %>
