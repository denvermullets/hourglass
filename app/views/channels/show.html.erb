<div class="flex-1 flex flex-col lg:flex-row min-h-0 sidebar-container"
     data-controller="presence"
     data-presence-server-id-value="<%= @server.id %>">
  <%# Desktop sidebar %>
  <div class="hidden lg:flex">
    <%= render "servers/channel_sidebar", server: @server, categories: @categories, current_channel: @channel, unread_channel_ids: @unread_channel_ids %>
  </div>

  <%# Channel content %>
  <div class="flex-1 flex flex-col min-w-0 min-h-0 relative"
       data-controller="dropzone"
       data-dropzone-channel-name-value="<%= @channel.name %>"
       >
    <%# Channel header %>
    <div class="px-4 lg:px-5 py-3 border-b border-bunker-825 flex-shrink-0">
      <div class="flex items-center gap-2.5">
        <%# Mobile back button %>
        <%= link_to server_path(@server), class: "lg:hidden text-xs text-granny-smith-apple-600 no-underline flex-shrink-0" do %>
          &larr; back
        <% end %>

        <span class="text-bunker-500 text-xs flex-shrink-0">
          <% if @channel.voice? %>
            <svg class="w-3.5 h-3.5 inline-block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
              <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/>
            </svg>
          <% else %>
            #
          <% end %>
        </span>
        <span class="font-syne text-sm lg:text-base font-bold text-bunker-50"><%= @channel.name %></span>

        <div class="ml-auto flex gap-1.5">
          <% if current_membership&.can_manage_channels? %>
            <%= link_to "settings", server_channel_settings_path(@server, @channel),
              class: "text-xs text-bunker-500 hover:text-bunker-300 transition-colors duration-100 no-underline" %>
          <% end %>
        </div>
      </div>

      <%# Stats row %>
      <div class="flex items-center gap-1.5 mt-1.5 text-xs text-bunker-500 font-dm-mono">
        <% if @channel.topic.present? %>
          <span><%= @channel.topic %></span>
          <span class="text-bunker-825">&bull;</span>
        <% end %>
        <span>msgs: <%= @message_count %></span>
        <span class="text-bunker-825">&bull;</span>
        <%= render "channels/pinned_count", server: @server, channel: @channel %>
        <span class="text-bunker-825">&bull;</span>
        <%= render "shared/presence_indicator", server_id: @server.id, online_count: PresenceChannel.online_count(@server.id) %>
        <% if @channel.mtasks_project_link %>
          <span class="text-bunker-825">&bull;</span>
          <%= render "channels/jait_linked_badge", channel: @channel %>
        <% end %>
      </div>
    </div>

    <%# Message area %>
    <div class="flex-1 flex flex-col min-h-0 overflow-hidden"
         data-controller="messages-scroll message-actions"
         data-message-actions-current-user-value="<%= Current.user.id %>">

      <%# Turbo Stream subscriptions for real-time updates %>
      <%= turbo_stream_from @channel %>
      <%= turbo_stream_from "server_#{@server.id}_presence" %>
      <%= turbo_stream_from "user_#{Current.user.id}_unread" %>

      <%# Mark channel as read after page loads (lazy frame avoids prefetch triggering) %>
      <%= turbo_frame_tag "mark_read", src: mark_read_server_channel_path(@server, @channel), loading: :lazy %>

      <%# Scrollable message container %>
      <div class="flex-1 overflow-y-auto" data-messages-scroll-target="container">
        <%# Load older messages %>
        <% if @has_older %>
          <div id="load_older" class="text-center py-3" data-messages-scroll-target="loadOlder">
            <%= link_to "load older messages",
                  server_channel_messages_path(@server, @channel, before: @messages.first.created_at.iso8601(6), format: :turbo_stream),
                  data: { turbo_stream: true },
                  class: "text-xs text-bunker-500 hover:text-bunker-300 transition-colors duration-100 no-underline" %>
          </div>
        <% else %>
          <div id="load_older"></div>
        <% end %>

        <%# Messages list %>
        <div id="messages" class="px-4 lg:px-5 py-2 space-y-0.5">
          <% if @messages.empty? %>
            <div class="text-center py-8">
              <div class="text-xs text-bunker-500 mb-1">welcome to <span class="text-bunker-300">#<%= @channel.name %></span></div>
              <div class="text-xs text-bunker-600">send the first message!</div>
            </div>
          <% else %>
            <% previous_date = nil %>
            <% previous_message = nil %>
            <% @messages.each do |message| %>
              <% if local_date(message.created_at) != previous_date %>
                <%= render "messages/date_separator", date: message.created_at %>
                <% previous_date = local_date(message.created_at) %>
                <% previous_message = nil %>
              <% end %>
              <%= render "messages/message", message: message, grouped: grouped_with_previous?(message, previous_message) %>
              <% previous_message = message %>
            <% end %>
          <% end %>
        </div>
      </div>

      <%# Message input (pinned to bottom) %>
      <div class="px-4 lg:px-5 py-3 pb-[calc(0.75rem+env(safe-area-inset-bottom))] lg:pb-3 border-t border-bunker-825 flex-shrink-0 relative z-10 bg-bunker-950">
        <%= render "messages/form", server: @server, channel: @channel %>
      </div>
    </div>

    <%# Drag-and-drop overlay %>
    <div data-dropzone-target="overlay"
         class="hidden absolute inset-0 bg-bunker-950/85 z-10 flex items-center justify-center">
      <div class="border-2 border-dashed border-granny-smith-apple-600 rounded-lg p-12 flex flex-col items-center gap-3.5 bg-granny-smith-apple-925">
        <div class="font-syne text-4xl font-extrabold text-granny-smith-apple-300 leading-none">&darr;</div>
        <div class="text-sm text-granny-smith-apple-300 tracking-[0.06em]">// drop to attach</div>
        <div class="text-xs text-granny-smith-apple-600 leading-relaxed text-center">
          files will be attached to your next message in<br>
          <span class="text-bunker-300"># <%= @channel.name %></span>
        </div>
        <div class="flex gap-1.5 flex-wrap justify-center mt-1">
          <span class="border border-granny-smith-apple-600 rounded-sm px-2 py-0.5 text-xs text-granny-smith-apple-600">jpg &middot; png &middot; gif &middot; webp</span>
          <span class="border border-granny-smith-apple-600 rounded-sm px-2 py-0.5 text-xs text-granny-smith-apple-600">mp3 &middot; wav</span>
          <span class="border border-granny-smith-apple-600 rounded-sm px-2 py-0.5 text-xs text-granny-smith-apple-600">mp4 &middot; mov</span>
          <span class="border border-granny-smith-apple-600 rounded-sm px-2 py-0.5 text-xs text-granny-smith-apple-600">pdf &middot; zip &middot; any</span>
        </div>
        <div class="text-xs text-granny-smith-apple-600 mt-1">max 50mb per file</div>
      </div>
    </div>
  </div>
</div>
