<%# Mobile bottom navigation — matches .references/cold_wave_mobile.html %>
<nav class="fixed bottom-0 left-0 right-0 border-t border-bunker-825 bg-bunker-950 py-2 flex justify-around items-center z-50">
  <%# Servers %>
  <%= link_to servers_path, class: "flex flex-col items-center gap-0.5 px-2.5 no-underline #{controller_name == 'servers' && action_name == 'index' ? 'text-granny-smith-apple-300' : 'text-bunker-600'}" do %>
    <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 5h18M3 12h18M3 19h18"/>
    </svg>
    <span class="text-[7px] tracking-[0.08em]">servers</span>
  <% end %>

  <%# DMs (placeholder) %>
  <div class="flex flex-col items-center gap-0.5 px-2.5 text-bunker-600 cursor-pointer relative">
    <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
    <span class="text-[7px] tracking-[0.08em]">dms</span>
  </div>

  <%# Search (placeholder) %>
  <div class="flex flex-col items-center gap-0.5 px-2.5 text-bunker-600 cursor-pointer">
    <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
    </svg>
    <span class="text-[7px] tracking-[0.08em]">search</span>
  </div>

  <%# Profile (placeholder) %>
  <div class="flex flex-col items-center gap-0.5 px-2.5 text-bunker-600 cursor-pointer">
    <div class="w-[18px] h-[18px] rounded flex items-center justify-center text-[6px] bg-bunker-875 border border-bunker-775">
      <%= Current.user.username[0, 2].upcase %>
    </div>
    <span class="text-[7px] tracking-[0.08em]">you</span>
  </div>
</nav>
