<%# Desktop icon rail — 52px wide, matches .references/cold_wave_dm_view.html %>
<nav class="w-13 flex-shrink-0 border-r border-bunker-825 flex flex-col items-center py-3 gap-1">
  <%# Logo %>
  <%= link_to servers_path, class: "font-syne text-base font-extrabold tracking-tight text-bunker-50 mb-2.5 no-underline" do %>
    h<span class="text-granny-smith-apple-300">.</span>
  <% end %>

  <%# Server icons %>
  <% Current.user.servers.each do |server| %>
    <%= link_to server_path(server),
      class: "w-8.5 h-8.5 rounded-lg flex items-center justify-center text-xs cursor-pointer transition-all duration-100 border #{current_server&.id == server.id ? 'bg-bunker-875 border-bunker-775 text-granny-smith-apple-300' : 'bg-transparent border-transparent text-bunker-500 hover:bg-bunker-875 hover:text-bunker-300'}",
      title: server.name do %>
      <% if server.icon.attached? %>
        <%= image_tag server.icon, alt: server.name, class: "w-full h-full rounded-lg object-cover" %>
      <% else %>
        <%= server.name[0, 2].upcase %>
      <% end %>
    <% end %>
  <% end %>

  <%# Create server %>
  <%= link_to new_server_path,
    class: "w-8.5 h-8.5 rounded-lg flex items-center justify-center text-bunker-500 hover:bg-bunker-875 hover:text-bunker-300 transition-all duration-100 border border-transparent",
    title: "Create server" do %>
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 5v14M5 12h14"/>
    </svg>
  <% end %>

  <%# Separator %>
  <div class="w-6 h-px bg-bunker-825 my-1"></div>

  <%# DMs %>
  <%= link_to conversations_path,
    class: "w-8.5 h-8.5 rounded-lg flex items-center justify-center transition-all duration-100 border #{controller_name == 'conversations' || controller_name == 'conversation_messages' || controller_name == 'conversation_threads' ? 'bg-bunker-875 border-bunker-775 text-granny-smith-apple-300' : 'text-bunker-500 hover:bg-bunker-875 hover:text-bunker-300 border-transparent'}",
    title: "Direct messages" do %>
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
  <% end %>

  <%# Notifications %>
  <button
    class="w-8.5 h-8.5 rounded-lg flex items-center justify-center text-bunker-500 hover:bg-bunker-875 hover:text-bunker-300 transition-all duration-100 border border-transparent relative cursor-pointer"
    title="Notifications"
    data-action="click->notification-panel#toggle">
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
      <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
    </svg>
    <span id="notification_badge">
      <%= render "notifications/badge" %>
    </span>
  </button>

  <%# Settings %>
  <%= link_to settings_path,
    class: "w-8.5 h-8.5 rounded-lg flex items-center justify-center transition-all duration-100 border #{controller_name == 'settings' ? 'bg-bunker-875 border-bunker-775 text-granny-smith-apple-300' : 'text-bunker-500 hover:bg-bunker-875 hover:text-bunker-300 border-transparent'}",
    title: "Settings" do %>
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="3"/>
      <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
    </svg>
  <% end %>

  <%# User avatar — pushed to bottom %>
  <div class="mt-auto relative">
    <div class="w-7 h-7 rounded-md bg-bunker-875 border border-bunker-775 flex items-center justify-center text-xs text-bunker-500 cursor-pointer">
      <%= Current.user.username[0, 2].upcase %>
    </div>
    <div class="absolute -bottom-0.5 -right-0.5 w-2 h-2 rounded-full bg-granny-smith-apple-600 border-2 border-bunker-950"></div>
  </div>
</nav>
