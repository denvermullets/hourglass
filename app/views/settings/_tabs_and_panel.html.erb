<%= turbo_frame_tag "user_settings_panel", class: "flex-1 flex flex-col lg:flex-row min-h-0" do %>
  <%# Mobile tab nav %>
  <div class="lg:hidden flex border-b border-bunker-825">
    <% %w[profile account notifications appearance].each do |t| %>
      <%= link_to send("#{t}_settings_path"),
        data: { turbo_frame: "user_settings_panel" },
        class: "flex-1 text-center py-2.5 text-[10px] no-underline transition-colors duration-100 #{tab == t ? 'text-granny-smith-apple-300 border-b-2 border-granny-smith-apple-300' : 'text-bunker-600'}" do %>
        <%= t %>
      <% end %>
    <% end %>
  </div>

  <%# Desktop sidebar nav %>
  <div class="hidden lg:block w-[200px] border-r border-bunker-825 py-4 flex-shrink-0">
    <div class="text-[8px] tracking-[0.2em] text-bunker-600 px-4 mb-2">
      <span class="text-bunker-700">//</span> settings
    </div>
    <% %w[profile account notifications appearance].each do |t| %>
      <%= link_to send("#{t}_settings_path"),
        data: { turbo_frame: "user_settings_panel" },
        class: "block w-full text-left px-4 py-2 text-[11px] no-underline transition-colors duration-100 #{tab == t ? 'text-granny-smith-apple-300 bg-bunker-875 border-r-2 border-granny-smith-apple-300' : 'text-bunker-600 hover:text-bunker-400 hover:bg-bunker-925'}" do %>
        <%= t %>
      <% end %>
    <% end %>
  </div>

  <%# Panel content %>
  <div class="flex-1 p-4 pb-24 lg:p-6 lg:pb-6 overflow-y-auto">
    <%= render panel_partial, **panel_locals %>
  </div>
<% end %>
