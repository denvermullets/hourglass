<% panel_classes = "rounded border border-granny-smith-apple-700 bg-bunker-875 p-3 space-y-2" %>
<% raw_classes = "block w-full font-dm-mono text-xs text-granny-smith-apple-300 break-all select-all" %>
<% copy_classes = "rounded px-2.5 py-1.5 font-dm-mono text-[11px] tracking-[0.06em] cursor-pointer transition-colors duration-150 bg-transparent border border-granny-smith-apple-600 text-granny-smith-apple-300 hover:bg-granny-smith-apple-600 hover:text-bunker-950" %>

<div class="<%= panel_classes %>" data-controller="clipboard">
  <div class="flex items-start justify-between gap-2">
    <div class="text-xs text-bunker-200">
      <span class="text-granny-smith-apple-400">// </span>
      token created. copy it now &mdash; you won't see this value again.
    </div>
  </div>
  <code data-clipboard-target="source" class="<%= raw_classes %>"><%= plaintext %></code>
  <div class="flex items-center justify-between gap-2">
    <span class="font-dm-mono text-[11px] text-bunker-500"><%= token.name %></span>
    <button type="button" data-action="clipboard#copy" class="<%= copy_classes %>">
      // copy →
    </button>
  </div>
</div>
