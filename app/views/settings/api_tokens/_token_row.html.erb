<% scope_badge_classes = "inline-flex items-center gap-1 rounded border border-bunker-775 bg-bunker-925 px-2 py-0.5 font-dm-mono text-[10px] tracking-[0.1em] uppercase text-bunker-400" %>
<% revoke_classes = "rounded px-2.5 py-1.5 font-dm-mono text-[11px] tracking-[0.06em] cursor-pointer transition-colors duration-150 bg-transparent border border-red-800 text-red-400 hover:bg-red-900 hover:text-red-200" %>

<div id="<%= dom_id(token) %>" class="rounded border border-bunker-825 bg-bunker-925 p-3 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
  <div class="flex flex-col gap-1 min-w-0">
    <div class="flex items-center gap-2 flex-wrap">
      <span class="font-dm-mono text-xs text-bunker-200 truncate"><%= token.name %></span>
      <span class="font-dm-mono text-[10px] text-bunker-600">•••<%= token.digest_preview %></span>
    </div>
    <div class="flex items-center gap-2 flex-wrap">
      <% token.scopes.each do |s| %>
        <span class="<%= scope_badge_classes %>"><%= s %></span>
      <% end %>
    </div>
    <div class="font-dm-mono text-[11px] text-bunker-500">
      created <%= token.created_at.strftime('%Y-%m-%d') %>
      <span class="text-bunker-700">·</span>
      last used <%= token.last_used_at ? time_ago_in_words(token.last_used_at) + ' ago' : 'never' %>
    </div>
  </div>

  <%= button_to settings_api_token_path(token),
    method: :delete,
    form: { data: { turbo_confirm: "Revoke this token? Anything using it will stop working immediately." } },
    class: revoke_classes do %>
    revoke
  <% end %>
</div>
