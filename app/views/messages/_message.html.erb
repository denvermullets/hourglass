<% grouped = local_assigns.fetch(:grouped, false) %>
<%= tag.div id: dom_id(message), class: "group flex gap-3 px-2 #{ grouped ? '-mt-0.5' : 'py-1.5' } rounded hover:bg-bunker-875/50 transition-colors duration-100", data: { message_author_id: message.user_id, message_user_id: message.user_id, message_created_at: message.created_at.iso8601, controller: "long-press" } do %>
  <% if message.deleted? %>
    <div class="flex-1 text-[11px] text-bunker-700 italic">
      [message deleted]
    </div>
  <% else %>
    <% if grouped %>
      <%# Spacer matching avatar width for text alignment %>
      <div class="flex-shrink-0 w-8"></div>
    <% else %>
      <%# Avatar %>
      <div class="flex-shrink-0 w-8 h-8 rounded-md bg-bunker-825 border border-bunker-775 flex items-center justify-center overflow-hidden">
        <% if message.user.avatar.attached? %>
          <%= image_tag polymorphic_path(message.user.avatar), alt: "", class: "w-full h-full object-cover" %>
        <% else %>
          <span class="text-[11px] font-syne font-bold text-bunker-400 uppercase"><%= message.user.username[0] %></span>
        <% end %>
      </div>
    <% end %>

    <div class="flex-1 min-w-0">
      <% unless grouped %>
        <%# Header: username + timestamp %>
        <div class="flex items-baseline gap-2">
          <span class="font-syne text-[11px] font-bold text-jordy-blue-400 message-username" data-author-name><%= message.user.username %></span>
          <span class="text-[9px] text-bunker-700"><%= format_timestamp(message.created_at, style: :message) %></span>
          <% if message.edited? %>
            <span class="text-[9px] text-bunker-700">(edited)</span>
          <% end %>
        </div>
      <% end %>

      <%# Body %>
      <% if message.body.present? %>
        <div class="text-[11px] text-bunker-400 break-words message-content"><%= sanitize_message(message.body) %></div>
      <% end %>

      <%# Attachments %>
      <% if message.files.attached? %>
        <%= render "messages/attachments", message: message %>
      <% end %>

      <%# Reply indicator %>
      <% if message.parent_message_id.nil? %>
        <%= render "messages/reply_indicator", message: message %>
      <% end %>

      <%# Actions (hover on desktop, tap on mobile) — below message content %>
      <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-100 flex items-center gap-2 mt-1"
           data-long-press-target="actions">
        <%# Reply — visible to all users %>
        <% if message.parent_message_id.nil? %>
          <%= link_to "reply",
                server_channel_message_thread_path(message.channel.server, message.channel, message),
                class: "text-[9px] leading-none text-bunker-700 hover:text-bunker-400 transition-colors duration-100 no-underline" %>
        <% end %>

        <%# Edit/Delete — author only %>
        <div class="hidden items-center gap-2" data-author-only>
          <%= link_to "edit",
                edit_server_channel_message_path(message.channel.server, message.channel, message),
                class: "text-[9px] leading-none text-bunker-700 hover:text-bunker-400 transition-colors duration-100 no-underline",
                data: { turbo_method: :get, turbo_prefetch: false } %>
          <%= link_to "delete",
                server_channel_message_path(message.channel.server, message.channel, message),
                class: "text-[9px] leading-none text-bunker-700 hover:text-danger-400 transition-colors duration-100 no-underline",
                data: { turbo_method: :delete, turbo_confirm: "Delete this message?" } %>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
