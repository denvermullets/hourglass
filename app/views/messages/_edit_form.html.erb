<% edit_context = local_assigns.fetch(:context, :channel) %>
<%= tag.div id: dom_id(message), class: "group flex gap-3 px-2 py-1.5" do %>
  <div class="flex-shrink-0 w-8 h-8 rounded-full bg-bunker-825 flex items-center justify-center">
    <span class="text-xs font-syne font-bold text-bunker-300 uppercase"><%= message.user.username[0] %></span>
  </div>

  <div class="flex-1 min-w-0">
    <div class="flex items-baseline gap-2 mb-1">
      <span class="font-syne text-xs font-bold text-bunker-50"><%= message.user.username %></span>
      <span class="text-xs text-bunker-600">editing</span>
    </div>

    <% edit_url = edit_context == :conversation ? conversation_message_path(conversation, message) : server_channel_message_path(server, channel, message) %>
    <% show_url = edit_context == :conversation ? conversation_message_path(conversation, message) : server_channel_message_path(server, channel, message) %>
    <% server_id_val = edit_context == :conversation ? "" : server.id %>
    <% channel_id_val = edit_context == :conversation ? "" : channel.id %>
    <%= form_with model: message,
                  url: edit_url,
                  method: :patch,
                  data: {
                    controller: "message-input attachment-upload",
                    message_input_server_id_value: server_id_val,
                    message_input_channel_id_value: channel_id_val
                  } do |f| %>
      <input type="file" multiple class="hidden" data-attachment-upload-target="fileInput" data-action="change->attachment-upload#filesSelected">

      <div class="bg-bunker-875 border border-bunker-825 rounded-lg overflow-clip focus-within:border-granny-smith-apple-600 transition-colors duration-150">
        <%# Existing attachments + new attachment preview strip %>
        <div data-attachment-upload-target="previewStrip"
             class="<%= message.files.attached? ? '' : 'hidden' %> border-b border-bunker-825 px-3 py-2 flex gap-2 items-center overflow-x-auto scrollbar-none"
             data-existing-rendered="true">
          <% if message.files.attached? %>
            <% message.files.each do |file| %>
              <div class="w-13 h-13 rounded flex-shrink-0 relative overflow-hidden border border-bunker-825 bg-bunker-875" data-existing-file="<%= file.id %>">
                <% if file.content_type.start_with?('image/') %>
                  <%= image_tag rails_representation_path(file.variant(resize_to_fill: [104, 104])),
                               alt: file.filename.to_s,
                               class: "w-full h-full object-cover" %>
                <% else %>
                  <div class="w-full h-full flex flex-col items-center justify-center gap-0.5">
                    <span class="text-xs font-medium text-bunker-300"><%= File.extname(file.filename.to_s).delete('.').upcase %></span>
                    <span class="text-xs text-bunker-600 text-center px-0.5 truncate max-w-full"><%= file.filename %></span>
                  </div>
                <% end %>
                <button type="button"
                        data-action="click->attachment-upload#removeExistingFile"
                        data-file-id="<%= file.id %>"
                        class="absolute top-0.5 right-0.5 w-3.5 h-3.5 rounded-full bg-bunker-950/90 border border-bunker-825 flex items-center justify-center text-xs text-bunker-300 cursor-pointer leading-none hover:text-bunker-50">&times;</button>
              </div>
            <% end %>
          <% end %>
        </div>

        <%# Markdown textarea %>
        <%= f.text_area :body,
              rows: 1,
              data: {
                message_input_target: "textarea",
                action: "paste->attachment-upload#handlePaste drop->attachment-upload#handleDrop dragover->attachment-upload#handleDragOver"
              },
              class: "block w-full resize-none min-h-15 max-h-100 overflow-y-auto px-3 py-2.5 text-xs text-bunker-50 placeholder:text-bunker-600 font-dm-mono bg-transparent border-0 focus:outline-none focus:ring-0" %>

        <%# Toolbar footer %>
        <div class="flex items-center gap-1 px-2 py-1.5 border-t border-bunker-825">
          <button type="button" data-action="mousedown->message-input#preventFocusLoss click->message-input#bold" data-format="bold"
                  class="toolbar-btn" title="Bold"><strong>B</strong></button>
          <button type="button" data-action="mousedown->message-input#preventFocusLoss click->message-input#italic" data-format="italic"
                  class="toolbar-btn" title="Italic"><em>I</em></button>
          <button type="button" data-action="mousedown->message-input#preventFocusLoss click->message-input#strikethrough" data-format="strikethrough"
                  class="toolbar-btn" title="Strikethrough"><s>S</s></button>
          <button type="button" data-action="mousedown->message-input#preventFocusLoss click->message-input#code" data-format="code"
                  class="toolbar-btn" title="Inline Code">&lt;/&gt;</button>
          <button type="button" data-action="mousedown->message-input#preventFocusLoss click->message-input#codeBlock"
                  class="toolbar-btn" title="Code Block">{}</button>

          <button type="button" data-action="mousedown->message-input#preventFocusLoss click->attachment-upload#openFilePicker"
                  class="toolbar-btn" title="Attach file">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="17 8 12 3 7 8"></polyline>
              <line x1="12" y1="3" x2="12" y2="15"></line>
            </svg>
          </button>

          <div class="ml-auto flex gap-2 items-center">
            <%= f.submit "save",
                  class: "text-xs text-granny-smith-apple-300 hover:text-granny-smith-apple-600 transition-colors duration-100 bg-transparent border-0 p-0 cursor-pointer font-dm-mono" %>
            <%= link_to "cancel", show_url,
                  class: "text-xs text-bunker-500 hover:text-bunker-300 transition-colors duration-100 no-underline font-dm-mono",
                  data: { turbo_method: :get, turbo_prefetch: false } %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
