<% data = message.data || {} %>
<% timestamp = message.created_at.strftime('%-m/%-d · %H:%M') %>
<%= tag.div id: dom_id(message), class: "group px-2 py-1 my-0.5", data: { message_user_id: message.user_id, message_created_at: message.created_at.iso8601 } do %>
  <div class="border-l-2 border-granny-smith-apple-600 bg-bunker-925 px-3 py-2 rounded-r font-dm-mono">
    <div class="text-[11px] text-bunker-500 leading-none mb-1">
      <span class="text-granny-smith-apple-400">↳ system</span>
      <span class="text-bunker-700"> · </span>
      <span><%= timestamp %></span>
    </div>
    <div class="text-xs text-bunker-300 break-words"><%= message.body %></div>
  </div>
<% end %>
