<% data = message.data || {} %>
<% kind = data['kind'].to_s %>
<% if !message.deleted? && kind.present? %>
  <%= render "messages/system_card", message: message %>
<% else %>
  <% source = data['source'].to_s %>
  <%= tag.div id: dom_id(message), class: "group flex gap-2 px-2 py-1 my-0.5", data: { message_user_id: message.user_id, message_created_at: message.created_at.iso8601 } do %>
    <% unless message.deleted? %>
      <%# small webhook-y glyph in muted accent color %>
      <div class="flex-shrink-0 w-5 h-5 rounded-md flex items-center justify-center bg-bunker-925 border border-bunker-825 mt-0.5">
        <svg class="w-3 h-3 text-bunker-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 16.98h-5.99c-1.66 0-3.01-1.34-3.01-3s1.34-3 3.01-3H18M2 12h6.99M11 6.04l4 8.96M22 6.04l-4 8.96"/>
        </svg>
      </div>

      <div class="flex-1 min-w-0 text-[11px] text-bunker-500 leading-snug font-dm-mono italic">
        <%= sanitize_message(message) %>
        <% if source.present? %>
          <span class="ml-1 text-[10px] tracking-[0.1em] text-bunker-700 uppercase">via <%= source %></span>
        <% end %>
      </div>
    <% else %>
      <div class="flex-1 text-[11px] text-bunker-500 italic">[system message removed]</div>
    <% end %>
  <% end %>
<% end %>
