<%# locals: (message:, data:) %>
<div class="mb-2">
  <%= render "messages/mtasks_event/identifier_title", data: data %>
</div>

<% if data['branch_name'].present? %>
  <div class="flex items-center gap-2 flex-wrap text-xs text-bunker-500 font-dm-mono">
    <svg class="w-3 h-3 text-granny-smith-apple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="6" y1="3" x2="6" y2="15"/>
      <circle cx="18" cy="6" r="3"/>
      <circle cx="6" cy="18" r="3"/>
      <path d="M18 9a9 9 0 0 1-9 9"/>
    </svg>
    <% if data['branch_url'].present? %>
      <%= link_to data['branch_name'], data['branch_url'], target: "_blank", rel: "noopener",
            class: "text-bunker-300 hover:text-granny-smith-apple-300 no-underline" %>
    <% else %>
      <span class="text-bunker-300"><%= data['branch_name'] %></span>
    <% end %>
    <span>·</span>
    <span>by</span>
    <%= render "messages/mtasks_event/actor", data: data %>
  </div>
<% end %>
