<%# locals: (message:, data:) %>
<div class="flex items-baseline gap-2 mb-2 flex-wrap">
  <%= render "messages/mtasks_event/actor", data: data %>
  <span class="text-xs text-bunker-500">commented on</span>
  <% if data['project_name'].present? %>
    <span class="text-xs text-bunker-200"><%= data['project_name'] %></span>
  <% end %>
</div>

<% if data['comment_body'].present? %>
  <div class="border-l-2 border-bunker-775 pl-3 py-1 text-xs text-bunker-200 break-words leading-relaxed flex gap-2">
    <svg class="w-3 h-3 text-bunker-600 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
    <span><%= data['comment_body'] %></span>
  </div>
<% end %>
