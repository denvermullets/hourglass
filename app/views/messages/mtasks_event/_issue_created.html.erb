<%# locals: (message:, data:) %>
<div class="flex items-baseline gap-2 mb-2">
  <%= render "messages/mtasks_event/actor", data: data %>
  <span class="text-xs text-bunker-500">opened</span>
  <% if data['identifier'].present? %>
    <span class="font-dm-mono text-[11px] text-bunker-400"><%= data['identifier'] %></span>
  <% end %>
</div>

<% if data['title'].present? %>
  <div class="text-sm text-bunker-100 break-words mb-3"><%= data['title'] %></div>
<% end %>

<%
  has_meta = data['status_lane_name'].present? ||
             data['priority'].present? ||
             data['assignee_email'].present? ||
             data['assignee_username'].present? ||
             data['assignee_name'].present? ||
             Array(data['labels']).any?
%>
<% if has_meta %>
  <div class="border-t border-dashed border-bunker-825 pt-2.5 flex flex-wrap items-center gap-x-3 gap-y-1.5 text-[11px] text-bunker-500 font-dm-mono">
    <% if data['status_lane_name'].present? %>
      <%= render "messages/mtasks_event/status_pill", name: data['status_lane_name'] %>
    <% end %>

    <% if data['priority'].present? %>
      <span>priority: <span class="text-bunker-300"><%= data['priority'] %></span></span>
    <% end %>

    <% if data['assignee_email'].present? || data['assignee_username'].present? || data['assignee_name'].present? %>
      <%= render "messages/mtasks_event/user_pill",
            email: data['assignee_email'],
            username: data['assignee_username'],
            name: data['assignee_name'] %>
    <% end %>

    <% if Array(data['labels']).any? %>
      <span class="inline-flex items-center gap-1">
        <svg class="w-3 h-3 text-bunker-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
          <line x1="7" y1="7" x2="7.01" y2="7"/>
        </svg>
        <%= Array(data['labels']).map { |l| l['name'] }.compact_blank.join(', ') %>
      </span>
    <% end %>
  </div>
<% end %>
