<%# locals: (message:, data:) %>
<div class="mb-2">
  <%= render "messages/mtasks_event/identifier_title", data: data %>
</div>

<div class="flex items-center gap-2 flex-wrap text-xs text-bunker-500 font-dm-mono">
  <%= render "messages/mtasks_event/actor", data: data %>
  <span>moved</span>
  <% if data['from_lane_name'].present? %>
    <%= render "messages/mtasks_event/status_pill", name: data['from_lane_name'] %>
  <% end %>
  <span>→</span>
  <% if data['to_lane_name'].present? %>
    <%= render "messages/mtasks_event/status_pill", name: data['to_lane_name'] %>
  <% end %>
</div>
