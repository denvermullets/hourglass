<div class="flex-1 flex flex-col">
  <%# Header %>
  <div class="px-4 lg:px-6 py-4 border-b border-bunker-825">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="font-syne text-[17px] lg:text-[20px] font-bold text-bunker-50 tracking-tight">
          your servers
        </h1>
        <div class="text-[8px] tracking-[0.16em] mt-1 text-bunker-500">
          <span class="text-granny-smith-apple-600">//</span> <%= @servers.count %> server<%= @servers.count == 1 ? "" : "s" %>
        </div>
      </div>
      <div class="flex gap-2">
        <%= link_to new_server_path,
          class: "flex items-center gap-1.5 px-3 py-1.5 rounded text-[10px] border border-granny-smith-apple-600 text-granny-smith-apple-300 hover:bg-granny-smith-apple-600 hover:text-bunker-950 transition-colors duration-150 no-underline" do %>
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
          create
        <% end %>
      </div>
    </div>
  </div>

  <%# Join by invite code %>
  <div class="px-4 lg:px-6 py-3 border-b border-bunker-825">
    <%= form_with url: join_server_path, method: :post, class: "flex items-center gap-2" do |form| %>
      <div class="flex-1 flex items-center gap-2 bg-bunker-925 border border-bunker-825 rounded px-3 py-1.5">
        <span class="text-[10px] text-bunker-500">/</span>
        <%= form.text_field :invite_code,
          placeholder: "enter invite code...",
          class: "flex-1 bg-transparent border-none outline-none font-dm-mono text-[10px] text-bunker-300 placeholder-bunker-700" %>
      </div>
      <%= form.submit "join",
        class: "px-3 py-1.5 rounded text-[10px] border border-bunker-775 text-bunker-500 hover:bg-bunker-875 hover:text-bunker-300 cursor-pointer transition-colors duration-150 bg-transparent" %>
    <% end %>
  </div>

  <%# Server list %>
  <div class="flex-1 overflow-y-auto">
    <% if @servers.any? %>
      <% @servers.each do |server| %>
        <%= link_to server_path(server), class: "flex items-center gap-3 px-4 lg:px-6 py-3 border-b border-bunker-825 hover:bg-bunker-925 transition-colors duration-100 no-underline" do %>
          <%= render "servers/server_icon", server: server, size: "md" %>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] text-bunker-50"><%= server.name %></div>
            <div class="text-[9px] text-bunker-500 mt-0.5 truncate"><%= server.description.presence || "no description" %></div>
          </div>
          <div class="flex flex-col items-end gap-1 flex-shrink-0">
            <div class="text-[8px] text-bunker-600"><%= server.users.count %> member<%= server.users.count == 1 ? "" : "s" %></div>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="flex-1 flex items-center justify-center py-20">
        <div class="text-center">
          <div class="text-[11px] text-bunker-500 mb-3">you haven't joined any servers yet.</div>
          <div class="flex gap-2 justify-center">
            <%= link_to "create one", new_server_path,
              class: "px-3 py-1.5 rounded text-[10px] border border-granny-smith-apple-600 text-granny-smith-apple-300 hover:bg-granny-smith-apple-600 hover:text-bunker-950 transition-colors duration-150 no-underline" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
