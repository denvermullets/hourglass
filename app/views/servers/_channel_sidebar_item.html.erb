<%# Individual channel link in sidebar %>
<% active = current_channel&.id == channel.id %>
<% is_unread = local_assigns.fetch(:unread, false) && !active %>
<% base_classes = "flex items-center gap-2 mx-1.5 px-2 py-1 rounded text-xs transition-colors duration-100 no-underline relative" %>
<% state_classes = active ? 'bg-bunker-875 text-bunker-50' : 'text-bunker-400 hover:bg-bunker-900 hover:text-bunker-200 has-[[data-unread=true]]:text-bunker-100 has-[[data-unread=true]]:font-bold' %>
<%= link_to server_channel_path(server, channel), class: "#{base_classes} #{state_classes}" do %>
  <% if active %>
    <span class="absolute left-0 top-1 bottom-1 w-0.5 rounded-r bg-granny-smith-apple-300"></span>
  <% end %>
  <span class="text-bunker-500 text-xs flex-shrink-0">
    <% if channel.voice? %>
      <svg class="w-3 h-3 inline-block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/>
      </svg>
    <% elsif channel.announcement? %>
      <svg class="w-3 h-3 inline-block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
      </svg>
    <% else %>
      #
    <% end %>
  </span>
  <span class="truncate flex-1"><%= channel.name %></span>
  <span id="unread_indicator_channel_<%= channel.id %>" data-unread="<%= is_unread %>" class="flex-shrink-0 ml-auto flex items-center">
    <% if is_unread %>
      <span class="w-1.5 h-1.5 rounded-full bg-granny-smith-apple-400 block"></span>
    <% end %>
  </span>
<% end %>
