<%# Renders a server icon — image or initials fallback
    Locals: server (required), size: "sm" | "md" | "lg" (default: "md") %>
<% size ||= "md" %>
<% size_classes = { "sm" => "w-7 h-7 rounded-md text-xs", "md" => "w-8.5 h-8.5 rounded-lg text-xs", "lg" => "w-12 h-12 rounded-xl text-sm" }[size] %>

<div class="<%= size_classes %> bg-bunker-875 border border-bunker-775 flex items-center justify-center text-bunker-500 flex-shrink-0 overflow-hidden">
  <% if server.icon.attached? %>
    <%= image_tag server.icon, alt: server.name, class: "w-full h-full object-cover" %>
  <% else %>
    <%= server.name[0, 2].upcase %>
  <% end %>
</div>
