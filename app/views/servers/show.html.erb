<%= turbo_stream_from "user_#{Current.user.id}_unread" %>
<%= turbo_stream_from "server_#{@server.id}_sidebar" %>
<div class="flex-1 flex flex-col lg:flex-row sidebar-container">
  <%# Desktop sidebar — hidden on mobile %>
  <div class="hidden lg:flex">
    <%= render "servers/channel_sidebar", server: @server, categories: @categories, current_channel: nil, unread_channel_ids: @unread_channel_ids %>
  </div>

  <%# Mobile channel list %>
  <div class="lg:hidden flex-1 flex flex-col">
    <%# Mobile header %>
    <div class="px-4 py-3 border-b border-bunker-825 flex items-center justify-between">
      <div>
        <h1 class="font-syne text-lg font-bold text-bunker-50 tracking-tight"><%= @server.name %></h1>
        <div class="text-xs tracking-[0.16em] mt-0.5 text-bunker-500">
          <span class="text-granny-smith-apple-600">//</span> <%= @server.users.count %> member<%= @server.users.count == 1 ? "" : "s" %>
        </div>
      </div>
      <div class="flex gap-1.5">
        <% if current_membership&.can_manage_server? %>
          <%= link_to settings_server_path(@server),
            class: "w-7 h-7 rounded flex items-center justify-center border border-bunker-775 text-bunker-500 hover:bg-bunker-875 hover:text-bunker-300 transition-colors duration-100 no-underline" do %>
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# Mobile channel list — matches cold_wave_mobile.html reference %>
    <div id="mobile_categories_server_<%= @server.id %>" class="flex-1 overflow-y-auto">
      <% @categories.each do |category| %>
        <%= render "servers/channel_sidebar_category", category: category, server: @server, current_channel: nil, mobile: true, unread_channel_ids: @unread_channel_ids %>
      <% end %>

      <% if current_membership&.can_create_categories? %>
        <div class="px-4 py-3 border-t border-bunker-825">
          <%= render "categories/form", server: @server %>
        </div>
      <% end %>

      <%= link_to changelog_path,
        class: "flex items-center gap-2 px-4 py-3 border-t border-bunker-825 text-xs text-bunker-500 hover:bg-bunker-875 hover:text-bunker-300 no-underline" do %>
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 22h14a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/>
          <path d="M18 14h-8M15 18h-5M10 6h8v4h-8z"/>
        </svg>
        <span class="tracking-[0.16em]"><span class="text-granny-smith-apple-600">//</span> what's new</span>
      <% end %>
    </div>
  </div>

  <%# Desktop welcome — no channel selected %>
  <div class="hidden lg:flex flex-1 items-center justify-center">
    <div class="text-center">
      <div class="font-syne text-base font-bold text-bunker-200 mb-1">welcome to <%= @server.name %></div>
      <div class="text-xs text-bunker-500">select a channel from the sidebar to get started.</div>
    </div>
  </div>
</div>
