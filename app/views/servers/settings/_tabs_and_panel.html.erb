<%# Rendered inside turbo_frame_tag "settings_panel" — both the nav tabs and panel content
    so that active state updates when switching tabs.
    Locals: server, tab, panel_partial, panel_locals %>
<%= turbo_frame_tag "settings_panel", class: "flex-1 flex flex-col lg:flex-row min-h-0" do %>
  <%# Mobile tab nav %>
  <div class="lg:hidden flex border-b border-bunker-825 overflow-x-auto scrollbar-none">
    <%= link_to settings_general_server_path(server),
      data: { turbo_frame: "settings_panel" },
      class: "shrink-0 whitespace-nowrap px-4 py-2.5 text-xs no-underline transition-colors duration-100 #{tab == 'general' ? 'text-granny-smith-apple-300 border-b-2 border-granny-smith-apple-300' : 'text-bunker-500'}" do %>
      general
    <% end %>
    <%= link_to settings_invite_server_path(server),
      data: { turbo_frame: "settings_panel" },
      class: "shrink-0 whitespace-nowrap px-4 py-2.5 text-xs no-underline transition-colors duration-100 #{tab == 'invite' ? 'text-granny-smith-apple-300 border-b-2 border-granny-smith-apple-300' : 'text-bunker-500'}" do %>
      invite
    <% end %>
    <%= link_to settings_channels_server_path(server),
      data: { turbo_frame: "settings_panel" },
      class: "shrink-0 whitespace-nowrap px-4 py-2.5 text-xs no-underline transition-colors duration-100 #{tab == 'channels' ? 'text-granny-smith-apple-300 border-b-2 border-granny-smith-apple-300' : 'text-bunker-500'}" do %>
      channels
    <% end %>
    <%= link_to settings_permissions_server_path(server),
      data: { turbo_frame: "settings_panel" },
      class: "shrink-0 whitespace-nowrap px-4 py-2.5 text-xs no-underline transition-colors duration-100 #{tab == 'permissions' ? 'text-granny-smith-apple-300 border-b-2 border-granny-smith-apple-300' : 'text-bunker-500'}" do %>
      permissions
    <% end %>
    <%= link_to settings_members_server_path(server),
      data: { turbo_frame: "settings_panel" },
      class: "shrink-0 whitespace-nowrap px-4 py-2.5 text-xs no-underline transition-colors duration-100 #{tab == 'members' ? 'text-granny-smith-apple-300 border-b-2 border-granny-smith-apple-300' : 'text-bunker-500'}" do %>
      members
    <% end %>
    <%= link_to settings_integrations_server_path(server),
      data: { turbo_frame: "settings_panel" },
      class: "shrink-0 whitespace-nowrap px-4 py-2.5 text-xs no-underline transition-colors duration-100 #{tab == 'integrations' ? 'text-granny-smith-apple-300 border-b-2 border-granny-smith-apple-300' : 'text-bunker-500'}" do %>
      integrations
    <% end %>
    <%= link_to settings_danger_server_path(server),
      data: { turbo_frame: "settings_panel" },
      class: "shrink-0 whitespace-nowrap px-4 py-2.5 text-xs no-underline transition-colors duration-100 #{tab == 'danger' ? 'text-granny-smith-apple-300 border-b-2 border-granny-smith-apple-300' : 'text-bunker-500'}" do %>
      danger
    <% end %>
  </div>

  <%# Desktop sidebar nav %>
  <div class="hidden lg:block w-[200px] border-r border-bunker-825 py-4 flex-shrink-0">
    <div class="text-xs tracking-[0.2em] text-bunker-500 px-4 mb-2">
      <span class="text-bunker-600">//</span> settings
    </div>
    <%= link_to settings_general_server_path(server),
      data: { turbo_frame: "settings_panel" },
      class: "block w-full text-left px-4 py-2 text-xs no-underline transition-colors duration-100 #{tab == 'general' ? 'text-granny-smith-apple-300 bg-bunker-875 border-r-2 border-granny-smith-apple-300' : 'text-bunker-500 hover:text-bunker-300 hover:bg-bunker-925'}" do %>
      general
    <% end %>
    <%= link_to settings_invite_server_path(server),
      data: { turbo_frame: "settings_panel" },
      class: "block w-full text-left px-4 py-2 text-xs no-underline transition-colors duration-100 #{tab == 'invite' ? 'text-granny-smith-apple-300 bg-bunker-875 border-r-2 border-granny-smith-apple-300' : 'text-bunker-500 hover:text-bunker-300 hover:bg-bunker-925'}" do %>
      invite
    <% end %>
    <%= link_to settings_channels_server_path(server),
      data: { turbo_frame: "settings_panel" },
      class: "block w-full text-left px-4 py-2 text-xs no-underline transition-colors duration-100 #{tab == 'channels' ? 'text-granny-smith-apple-300 bg-bunker-875 border-r-2 border-granny-smith-apple-300' : 'text-bunker-500 hover:text-bunker-300 hover:bg-bunker-925'}" do %>
      channels
    <% end %>
    <%= link_to settings_permissions_server_path(server),
      data: { turbo_frame: "settings_panel" },
      class: "block w-full text-left px-4 py-2 text-xs no-underline transition-colors duration-100 #{tab == 'permissions' ? 'text-granny-smith-apple-300 bg-bunker-875 border-r-2 border-granny-smith-apple-300' : 'text-bunker-500 hover:text-bunker-300 hover:bg-bunker-925'}" do %>
      permissions
    <% end %>
    <%= link_to settings_members_server_path(server),
      data: { turbo_frame: "settings_panel" },
      class: "block w-full text-left px-4 py-2 text-xs no-underline transition-colors duration-100 #{tab == 'members' ? 'text-granny-smith-apple-300 bg-bunker-875 border-r-2 border-granny-smith-apple-300' : 'text-bunker-500 hover:text-bunker-300 hover:bg-bunker-925'}" do %>
      members
    <% end %>
    <%= link_to settings_integrations_server_path(server),
      data: { turbo_frame: "settings_panel" },
      class: "block w-full text-left px-4 py-2 text-xs no-underline transition-colors duration-100 #{tab == 'integrations' ? 'text-granny-smith-apple-300 bg-bunker-875 border-r-2 border-granny-smith-apple-300' : 'text-bunker-500 hover:text-bunker-300 hover:bg-bunker-925'}" do %>
      integrations
    <% end %>
    <%= link_to settings_danger_server_path(server),
      data: { turbo_frame: "settings_panel" },
      class: "block w-full text-left px-4 py-2 text-xs no-underline transition-colors duration-100 #{tab == 'danger' ? 'text-granny-smith-apple-300 bg-bunker-875 border-r-2 border-granny-smith-apple-300' : 'text-bunker-500 hover:text-bunker-300 hover:bg-bunker-925'}" do %>
      danger zone
    <% end %>
  </div>

  <%# Panel content %>
  <div class="flex-1 min-h-0 p-4 lg:p-6 overflow-y-auto">
    <%= render panel_partial, **panel_locals %>
  </div>
<% end %>
