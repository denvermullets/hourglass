<%# Category section with collapsible channel list — native <details> element %>
<details open id="<%= mobile ? 'mobile' : 'desktop' %>_category_<%= category.id %>" class="<%= mobile ? 'border-b border-bunker-825' : '' %> group/cat">
  <%# Category header %>
  <summary class="flex items-center justify-between px-3.5 pt-2.5 pb-1 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
    <div class="flex items-center gap-1.5 flex-1 min-w-0">
      <svg class="w-2.5 h-2.5 text-bunker-700 transition-transform duration-150 group-open/cat:rotate-0 -rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
      <span class="text-[8px] tracking-[0.2em] uppercase text-bunker-600">
        <span class="text-bunker-700">//</span>
        <%= category.name %>
      </span>
    </div>

    <% if defined?(current_membership) && current_membership&.can_create_channels? %>
      <span class="opacity-0 group-hover/cat:opacity-100 w-4 h-4 flex items-center justify-center text-bunker-700 hover:text-bunker-400 transition-all duration-100">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5v14M5 12h14"/>
        </svg>
      </span>
    <% end %>
  </summary>

  <%# Channels list %>
  <div class="pb-1">
    <% category.channels.select { |c| !c.archived? }.sort_by(&:position).each do |channel| %>
      <%= render "servers/channel_sidebar_item", channel: channel, server: server, current_channel: current_channel, mobile: mobile, unread: local_assigns[:unread_channel_ids]&.include?(channel.id) %>
    <% end %>

    <%# Inline channel creation form — moderator+ %>
    <% if defined?(current_membership) && current_membership&.can_create_channels? %>
      <div class="px-3.5 py-1">
        <%= render "channels/form", server: server, category: category %>
      </div>
    <% end %>
  </div>
</details>
