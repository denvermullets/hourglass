<div class="flex-1 flex flex-col">
  <%# Header %>
  <div class="px-4 lg:px-6 py-4 border-b border-bunker-825 flex items-center gap-3">
    <%= link_to settings_server_path(@server), class: "text-[10px] text-granny-smith-apple-600 no-underline" do %>
      &larr; back
    <% end %>
    <div>
      <h1 class="font-syne text-[17px] lg:text-[20px] font-bold text-bunker-100 tracking-tight">edit server</h1>
      <div class="text-[8px] tracking-[0.16em] mt-1 text-bunker-600">
        <span class="text-granny-smith-apple-600">//</span> <%= @server.name %>
      </div>
    </div>
  </div>

  <%# Form %>
  <div class="flex-1 flex items-start justify-center p-4 lg:p-10">
    <div class="w-full max-w-[420px]">
      <%= render "shared/auth_flash" %>
      <%= render "servers/form", server: @server %>
    </div>
  </div>
</div>
